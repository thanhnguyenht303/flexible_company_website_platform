# Application
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://your-domain.com
APP_NAME="Flexible Company Website"
APP_SECRET="replace-with-a-random-64-character-hex-secret"

# Database - PostgreSQL default
DATABASE_PROVIDER=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=company_website
DATABASE_USER=company_user
DATABASE_PASSWORD=replace_with_a_strong_database_password
DATABASE_URL="postgresql://company_user:replace_with_a_strong_database_password@localhost:5432/company_website?schema=public"

# Admin bootstrap behavior
ALLOW_ADMIN_BOOTSTRAP=false

# Uploads
UPLOAD_DRIVER=local
LOCAL_UPLOAD_DIR=public/uploads
IMAGE_STORAGE_ROOT=../Images
FILE_STORAGE_ROOT=../files_storage
MAX_UPLOAD_MB=10
MAX_FILE_UPLOAD_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Email Center - environment values are fallbacks; admins can configure encrypted SMTP settings in the dashboard
MAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@your-domain.com

# Analytics - optional
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Security
SESSION_COOKIE_NAME=__Host-cw_session
SESSION_EXPIRES_HOURS=24
PASSWORD_MIN_LENGTH=10
RATE_LIMIT_LOGIN_PER_MINUTE=5
