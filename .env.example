# Application
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_NAME="Flexible Company Website"
APP_SECRET="change-this-long-random-secret-at-least-32-chars"

# Database - PostgreSQL default
DATABASE_PROVIDER=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=company_website
DATABASE_USER=company_user
DATABASE_PASSWORD=change_this_password
DATABASE_URL="postgresql://company_user:change_this_password@localhost:5432/company_website?schema=public"

# Admin bootstrap behavior
ALLOW_ADMIN_BOOTSTRAP=true

# Uploads
UPLOAD_DRIVER=local
LOCAL_UPLOAD_DIR=public/uploads
MAX_UPLOAD_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,image/svg+xml,application/pdf

# Email - optional for MVP contact notifications
MAIL_DRIVER=none
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@your-domain.com

# Analytics - optional
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Security
SESSION_COOKIE_NAME=cw_session
SESSION_EXPIRES_DAYS=7
PASSWORD_MIN_LENGTH=10
RATE_LIMIT_LOGIN_PER_MINUTE=5
