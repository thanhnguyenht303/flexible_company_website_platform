generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String?      @unique
  passwordHash String
  displayName  String?
  status       UserStatus   @default(ACTIVE)
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  mediaUploads MediaAsset[]
  auditLogs    AuditLog[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  siteName    String   @default("Demo Company")
  domain      String?
  tagline     String?
  description String?
  logoId      String?
  faviconId   String?
  email       String?
  phone       String?
  address     String?
  mapEmbedUrl String?
  socialLinks Json?
  defaultSeo  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ThemeSetting {
  id              String   @id @default(cuid())
  primaryColor    String   @default("#2563EB")
  secondaryColor  String   @default("#1E293B")
  accentColor     String   @default("#F97316")
  backgroundColor String   @default("#FFFFFF")
  backgroundImageId String?
  textColor       String   @default("#111827")
  fontFamily      String   @default("Inter")
  borderRadius    String   @default("medium")
  headerLayout    String   @default("classic")
  footerLayout    String   @default("standard")
  customCss       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Page {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  status         PublishStatus @default(DRAFT)
  template       String        @default("default")
  seoTitle       String?
  seoDescription String?
  seoImageId     String?
  sections       PageSection[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PageSection {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  title     String?
  subtitle  String?
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageBuilderDraft {
  id        String   @id @default(cuid())
  pageSlug  String   @unique
  title     String
  blocks    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Form {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String?
  status             PublishStatus    @default(DRAFT)
  successMessage     String?
  redirectUrl        String?
  notificationEmails String[]         @default([])
  sourceType         String           @default("form")
  linkedEntityType   String?
  linkedEntityId     String?
  settings           Json?
  fields             FormField[]
  submissions        FormSubmission[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status, sourceType])
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  type        String
  label       String
  key         String
  helpText    String?
  placeholder String?
  required    Boolean  @default(false)
  options     Json?
  validation  Json?
  defaultValue String?
  internalLabel String?
  sortOrder   Int      @default(0)
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([formId, key])
  @@index([formId, sortOrder])
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  values      Json
  files       Json?
  sourceType  String?
  sourceId    String?
  status      String   @default("NEW")
  ipAddress   String?
  userAgent   String?
  leadId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([formId, createdAt])
  @@index([status, createdAt])
}

model Lead {
  id            String   @id @default(cuid())
  submissionId  String?
  name          String?
  email         String?
  phone         String?
  companyName   String?
  sourceType    String   @default("form")
  sourceId      String?
  sourceFormId  String?
  status        String   @default("NEW")
  priority      String   @default("NORMAL")
  assignedToId  String?
  internalNote  String?
  followUpAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([priority, createdAt])
  @@index([sourceType, sourceId])
  @@index([sourceFormId])
}

model QaItem {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  question       String
  answer         String?
  submitterName  String?
  submitterEmail String?
  category       String?
  status         String   @default("NEW")
  sourceType     String?  @default("qa")
  sourceId       String?
  sourceFormId   String?
  submissionId   String?
  leadId         String?
  relatedType    String?
  relatedId      String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id             String        @id @default(cuid())
  name           String
  nameVi         String?
  slug           String        @unique
  summary        String?
  summaryVi      String?
  description    String?
  descriptionVi  String?
  categoryId     String?
  imageId        String?
  gallery        Json?
  specs          Json?
  status         PublishStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Service {
  id             String        @id @default(cuid())
  name           String
  nameVi         String?
  slug           String        @unique
  summary        String?
  summaryVi      String?
  description    String?
  descriptionVi  String?
  categoryId     String?
  imageId        String?
  gallery        Json?
  status         PublishStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reviews        ServiceReview[]
}

model ServiceReview {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String
  email     String
  rating    Int
  comment   String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId, isVisible, createdAt])
}

model Post {
  id              String        @id @default(cuid())
  title           String
  titleVi         String?
  slug            String        @unique
  excerpt         String?
  excerptVi       String?
  content         String
  contentVi       String?
  categoryId      String?
  tagNames        String[]
  featuredImageId String?
  status          PublishStatus @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  position    String?
  positionVi  String?
  bio         String?
  bioVi       String?
  photoId     String?
  email       String?
  phone       String?
  socialLinks Json?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FooterPartner {
  id         String   @id @default(cuid())
  name       String
  logoId     String
  websiteUrl String?
  sortOrder  Int      @default(0)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isVisible, sortOrder])
}

model JobPosting {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  summary        String?
  description    String
  requirements   String?
  department     String?
  location       String?
  employmentType String?
  workMode       String?
  salaryRange    String?
  applyEmail     String?
  applyUrl       String?
  status         PublishStatus @default(DRAFT)
  publishedAt    DateTime?
  applications   JobApplication[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, publishedAt])
}

model JobApplication {
  id          String        @id @default(cuid())
  jobId       String
  job         JobPosting    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  companyName String?
  message     String?
  resumeFileId String?
  resumeFile  FileAsset?    @relation(fields: [resumeFileId], references: [id])
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([jobId, createdAt])
}

model FileAsset {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  url          String
  category     String
  uploadedById String?
  createdAt    DateTime @default(now())
  applications JobApplication[]
}

model MediaAsset {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  url          String
  altText      String?
  title        String?
  description  String?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model Inquiry {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  companyName  String?
  message      String
  sourceType   String        @default("contact")
  sourceId     String?
  status       InquiryStatus @default(NEW)
  internalNote String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}
